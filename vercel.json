{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/styles.css", "dest": "/styles.css" },
    { "src": "/app.js", "dest": "/app.js" },
    { "src": "/dashboard.html", "dest": "/dashboard.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}